{
  "reference": "master",
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "HyperQL grammar for Tree-sitter",
    "authors": [
      {
        "name": "Jar Bear"
      }
    ],
    "links": {
      "repository": "https://github.com/your-username/tree-sitter-hyperql"
    }
  },
  "grammars": [
    {
      "name": "hyperql",
      "camelcase": "HyperQL",
      "scope": "source.hyperql",
      "file-types": ["hql", "hyperql"],
      "injection-regex": "^hyperql$"
    }
  ],
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
